# Redis password — used by docker-compose to start Redis with auth
# Not needed for local yarn dev (see below)
REDIS_PASSWORD=

# Redis connection URL — must spell out the password literally (no variable interpolation in .env files)
# docker-compose / Droplet: REDIS_URL=redis://:mysecretpassword@redis:6379
# yarn dev locally:          REDIS_URL=redis://localhost:6379
REDIS_URL=

# Your domain name — used by Caddy for automatic HTTPS via Let's Encrypt
# On Droplet: point your domain's A record to the droplet IP, then set this to your domain
# Local docker-compose: leave blank (Caddy will use HTTP only)
DOMAIN=

# Enable debug logging (server + browser console)
# Set to "true" in development, leave empty in production
NEXT_PUBLIC_DEBUG=
