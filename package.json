{
  "name": "jamroom",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "dev": "yarn build && yarn start",
    "lint": "next lint",
    "docker:start": "next start -p ${PORT:-8080}",
    "prod": "yarn && yarn build && yarn start",
    "test:smoke": "jest --testPathPattern=smoke --forceExit --detectOpenHandles",
    "docker:reset": "docker compose down && docker compose build --no-cache && docker compose up -d && docker compose logs app -f"
  },
  "resolutions": {
    "socket.io-adapter": "2.5.6"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "8.3.0",
    "classnames": "2.3.2",
    "ioredis": "5.10.1",
    "nanoid": "4.0.1",
    "next": "12.1.6",
    "next-pwa": "5.6.0",
    "react": "18.1.0",
    "react-dom": "18.1.0",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "tone": "14.7.77",
    "zustand": "4.3.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.7.11",
    "@types/react": "18.0.12",
    "@types/react-dom": "18.0.5",
    "eslint": "8.17.0",
    "eslint-config-next": "12.1.6",
    "jest": "^29.5.0",
    "nodemon": "^2.0.19",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "4.7.3"
  }
}
